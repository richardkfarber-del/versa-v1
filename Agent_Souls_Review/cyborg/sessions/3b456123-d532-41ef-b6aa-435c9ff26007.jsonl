iv>\n\n                    <!-- Password Field -->\n                    <div class=\"space-y-2\">\n                        <label class=\"block text-xs font-bold uppercase tracking-widest text-outline pl-1\" for=\"password\">Password</label>\n                        <div class=\"relative group\">\n                            <input class=\"w-full bg-surface-container-lowest border-none rounded-xl py-4 px-5 pr-12 text-on-surface placeholder:text-outline/50 focus:bg-surface-container-high focus:ring-2 focus:ring-primary/40 transition-all duration-300\" id=\"password\" placeholder=\"••••••••\" type=\"password\" required/>\n                            <button type=\"button\" id=\"togglePassword\" class=\"absolute right-4 top-1/2 -translate-y-1/2 text-outline/30 hover:text-primary transition-colors\">\n                                <span class=\"material-symbols-outlined\" id=\"eyeIcon\">visibility</span>\n                            </button>\n                        </div>\n                    </div>\n\n                    <!-- Remember Me & Forgot Password -->\n                    <div class=\"flex items-center justify-between px-1\">\n                        <label class=\"flex items-center gap-3 cursor-pointer group\">\n                            <div class=\"relative flex items-center\">\n                                <input type=\"checkbox\" id=\"rememberMe\" class=\"peer h-5 w-5 rounded border-outline-variant/30 bg-surface-container-lowest text-primary focus:ring-primary/40 focus:ring-offset-0 transition-all cursor-pointer\"/>\n                            </div>\n                            <span class=\"text-sm font-medium text-on-surface-variant group-hover:text-on-surface transition-colors\">Remember Me</span>\n                        </label>\n                        <a href=\"#\" class=\"text-xs font-bold uppercase tracking-widest text-outline hover:text-primary transition-colors\">Forgot?</a>\n                    </div>\n\n                    <!-- CTA 